# Zene P-E-R Architecture Configuration Example
# 设置为 true 启用简单模式 (单模型)，设置为 false 启用 PER 模式 (多模型协同)
ZENE_SIMPLE_MODE=false

# --- Planner (规划者) ---
# DeepSeek (API: https://api.deepseek.com/v1)
# 推荐使用 deepseek-reasoner (R1) 进行深度思考和规划
ZENE_PLANNER_PROVIDER=deepseek
ZENE_PLANNER_MODEL=deepseek-reasoner
ZENE_PLANNER_REGION=cn
ZENE_PLANNER_API_KEY=YOUR_DEEPSEEK_API_KEY

# --- Executor (执行者) ---
# Zhipu Global (API: https://api.z.ai/api/paas/v4)
# 推荐使用 glm-5 进行工具调用和执行
# 注意：region 设置为 global 以使用国际版
ZENE_EXECUTOR_PROVIDER=zhipu
ZENE_EXECUTOR_MODEL=glm-5
ZENE_EXECUTOR_REGION=global
ZENE_EXECUTOR_API_KEY=YOUR_ZHIPU_API_KEY

# --- Reflector (反思者) ---
# Minimax (API: https://api.minimax.chat/v1)
# 推荐使用 MiniMax-M2.5 进行结果校验
ZENE_REFLECTOR_PROVIDER=minimax
ZENE_REFLECTOR_MODEL=MiniMax-M2.5
ZENE_REFLECTOR_REGION=global
ZENE_REFLECTOR_API_KEY=YOUR_MINIMAX_API_KEY
